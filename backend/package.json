{
  "name": "@user-posts-portal/backend",
  "version": "1.0.0",
  "description": "Backend API with Express, TypeScript, and Clean Architecture",
  "private": true,
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "db:migrate": "node --import tsx/esm node_modules/knex/bin/cli.js migrate:latest --knexfile knexfile.ts",
    "db:seed": "node --import tsx/esm node_modules/knex/bin/cli.js seed:run --knexfile knexfile.ts",
    "db:rollback": "node --import tsx/esm node_modules/knex/bin/cli.js migrate:rollback --knexfile knexfile.ts",
    "db:reset": "node --import tsx/esm node_modules/knex/bin/cli.js migrate:rollback --all --knexfile knexfile.ts && node --import tsx/esm node_modules/knex/bin/cli.js migrate:latest --knexfile knexfile.ts"
  },
  "dependencies": {
    "@types/express-rate-limit": "^6.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "pg": "^8.19.0",
    "serverless-http": "^4.0.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/knex": "^0.16.1",
    "@types/node": "^20.11.16",
    "@types/serverless": "^3.12.28",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.2",
    "openapi-types": "^12.1.3",
    "serverless": "^3.40.0",
    "serverless-esbuild": "^1.57.0",
    "serverless-offline": "^13.9.0",
    "supertest": "^7.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
